rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null
        && request.auth.token.email != null;
    }

    function currentEmail() {
      return request.auth.token.email;
    }

    function teamPath(teamId) {
      return /databases/$(database)/documents/teams/$(teamId);
    }

    function teamData(teamId) {
      return get(teamPath(teamId)).data;
    }

    function isTeamMember(teamId) {
      return signedIn()
        && currentEmail() in teamData(teamId).memberEmails;
    }

    function isTeamLead(teamId) {
      return signedIn()
        && (
          currentEmail() == teamData(teamId).ownerEmail
          || currentEmail() in teamData(teamId).leadEmails
        );
    }

    function validTeam(data) {
      return data.ownerEmail is string
        && data.ownerUid is string
        && data.memberEmails is list
        && data.leadEmails is list
        && data.memberEmails.size() <= 100
        && data.leadEmails.size() <= 20
        && data.ownerEmail in data.memberEmails
        && data.ownerEmail in data.leadEmails
        && data.memberEmails.hasAll(data.leadEmails);
    }

    function issuePath(teamId, sessionId, issueId) {
      return /databases/$(database)/documents/teams/$(teamId)/sessions/$(sessionId)/issues/$(issueId);
    }

    function issueData(teamId, sessionId, issueId) {
      return get(issuePath(teamId, sessionId, issueId)).data;
    }

    match /teams/{teamId} {
      allow create: if signedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.ownerEmail == currentEmail()
        && request.resource.data.memberEmails == [currentEmail()]
        && request.resource.data.leadEmails == [currentEmail()]
        && validTeam(request.resource.data);

      allow read: if signedIn()
        && currentEmail() in resource.data.memberEmails;

      allow update: if isTeamLead(teamId)
        && request.resource.data.ownerUid == resource.data.ownerUid
        && request.resource.data.ownerEmail == resource.data.ownerEmail
        && validTeam(request.resource.data);

      allow delete: if isTeamLead(teamId);

      match /members/{memberEmail} {
        allow read: if isTeamMember(teamId);

        allow create, update: if isTeamLead(teamId)
          && request.resource.data.email == memberEmail
          && request.resource.data.email is string
          && request.resource.data.role in ['lead', 'member'];

        allow delete: if isTeamLead(teamId);
      }

      match /sessions/{sessionId} {
        allow read: if isTeamMember(teamId);

        allow create: if isTeamLead(teamId)
          && request.resource.data.createdByUid == request.auth.uid;

        allow update, delete: if isTeamLead(teamId);

        match /issues/{issueId} {
          allow read: if isTeamMember(teamId);

          allow create: if isTeamLead(teamId)
            && request.resource.data.createdByUid == request.auth.uid;

          allow update, delete: if isTeamLead(teamId);

          match /vote_status/{statusId} {
            allow read: if isTeamMember(teamId);

            allow create, update: if isTeamMember(teamId)
              && request.resource.data.userId == request.auth.uid
              && request.resource.data.voterEmail == currentEmail()
              && issueData(teamId, sessionId, issueId).status == 'voting'
              && request.resource.data.round == issueData(teamId, sessionId, issueId).currentRound;

            allow delete: if isTeamLead(teamId)
              || resource.data.userId == request.auth.uid;
          }

          match /votes/{voteId} {
            allow read: if isTeamMember(teamId)
              && (
                resource.data.userId == request.auth.uid
                || issueData(teamId, sessionId, issueId).status in ['revealed', 'estimated']
              );

            allow create, update: if isTeamMember(teamId)
              && request.resource.data.userId == request.auth.uid
              && request.resource.data.voterEmail == currentEmail()
              && request.resource.data.value in [0.5, 1, 2, 3, 5, 8, 13]
              && issueData(teamId, sessionId, issueId).status == 'voting'
              && request.resource.data.round == issueData(teamId, sessionId, issueId).currentRound;

            allow delete: if isTeamLead(teamId)
              || resource.data.userId == request.auth.uid;
          }
        }
      }
    }
  }
}
